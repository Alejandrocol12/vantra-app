generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Product {
  id          String    @id @default(cuid())
  name        String
  category    String
  flavor      String?
  puffs       Int?
  image       String?
  stock       Int       @default(0)
  minStock    Int       @default(0)
  cost        Float
  price       Float
  hasVariants Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sales       Sale[]
  variants    Variant[]
}

model Variant {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  stock     Int       @default(0)
  minStock  Int       @default(0)
  cost      Float
  price     Float
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sales     Sale[]
}

model Cliente {
  id             String     @id @default(cuid())
  name           String
  phone          String?
  note           String?
  limiteCredito  Float?
  createdAt      DateTime   @default(now())
  sales          Sale[]
  abonos         Abono[]
}

model Sale {
  id           String   @id @default(cuid())
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName  String
  variantId    String?
  variant      Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantLabel String?
  quantity     Int
  payment      String
  clienteId    String?
  cliente      Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  note         String?
  total        Float
  profit       Float
  status       String   @default("activa")
  date         DateTime @default(now())
}

model Abono {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  amount    Float
  note      String?
  date      DateTime @default(now())
}

model Movement {
  id           String   @id @default(cuid())
  reference    String
  productId    String
  productName  String
  variantId    String?
  variantLabel String?
  type         String
  quantity     Int
  stockBefore  Int
  stockAfter   Int
  note         String?
  date         DateTime @default(now())
}
